# Database
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/egide
CLICKHOUSE_URL=http://default:@localhost:8123/egide

# Redis (jobs, cache)
REDIS_URL=redis://localhost:6379

# LLM Router — pluggable providers (community supports BYOK and local)
# Anthropic API (cloud — BYOK by tenant)
ANTHROPIC_API_KEY=

# Mistral La Plateforme (sovereign FR)
MISTRAL_API_KEY=

# Scaleway / OVH AI (sovereign EU)
SCALEWAY_AI_KEY=
OVH_AI_KEY=

# Ollama / vLLM (self-hosted local)
LLM_LOCAL_URL=http://localhost:11434
LLM_LOCAL_MODEL=mistral:7b-instruct

# Operating mode
EGIDE_AI_MODE=template_only  # template_only | byok | local | hybrid
EGIDE_EDITION=community      # community | professional | enterprise

# Auth (Supabase or self-hosted SSO in Enterprise)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Object storage (S3-compatible — Scaleway / OVH / MinIO for sovereign)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=egide-evidence

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
