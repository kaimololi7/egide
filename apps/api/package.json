{
  "name": "@egide/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir=dist",
    "start": "bun src/server.ts",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@egide/db": "workspace:*",
    "@egide/llm-router": "workspace:*",
    "@egide/messaging": "workspace:*",
    "@egide/oscal": "workspace:*",
    "@hono/trpc-server": "^0.3.4",
    "@trpc/server": "^11.0.0-rc.500",
    "better-auth": "^1.0.5",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.1",
    "hono": "^4.6.5",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.1.10",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2",
    "vitest": "^2.1.4"
  }
}
