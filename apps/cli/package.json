{
  "name": "@egide/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "egide": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile=dist/egide --compile",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.1.10",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
